#!/bin/bash -l
#PBS -N zmvefluxyear
#PBS -A UNYU0024
#PBS -l select=1:ncpus=1:mpiprocs=1:mem=50GB
#PBS -l walltime=18:00:00
#PBS -q casper
#PBS -j oe

export TMPDIR=${SCRATCH}/temp
mkdir -p ${TMPDIR}

### Load Conda/Python module and activate NPL environment
module load conda
conda activate npl

### Run analysis script
python zmverteddyflux.py $YEAR